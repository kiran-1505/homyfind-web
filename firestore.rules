rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PG Advertisements — the main listing collection
    match /pg_advertisements/{listingId} {
      // Public reads allowed (for search and listing detail pages)
      allow read: if true;

      // Creates go through Admin SDK (server-side), which bypasses these rules.
      // This rule blocks direct client-side creates unless they have a valid ownerId.
      allow create: if request.auth != null
                    && request.resource.data.ownerId is string
                    && request.resource.data.ownerId == request.auth.uid;

      // Updates use Firestore REST API with user's ID token — enforce ownerId match.
      // Also prevent changing ownerId after creation.
      allow update: if request.auth != null
                    && resource.data.ownerId is string
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId;

      // Only the owner can delete their listing
      allow delete: if request.auth != null
                    && resource.data.ownerId is string
                    && resource.data.ownerId == request.auth.uid;
    }

    // User profiles — owner can read/write their own data only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Payments — authenticated users can read, writes only via Admin SDK (webhooks)
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
